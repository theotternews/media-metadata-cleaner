{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "os:allow-platform",
    "shell:allow-spawn",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "bin/media-metadata-cleaner_exiftool",
          "cmd": "sh",
          "args": true,
          "sidecar": true
        }
      ]
    },
    "dialog:default",
    "opener:default"
  ]
}