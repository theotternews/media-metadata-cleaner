{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "media-metadata-cleaner",
  "version": "0.3.0",
  "identifier": "org.otternews.media-metadata-cleaner",
  "build": {
    "beforeDevCommand": "bash scripts/get_latest_exiftool.sh && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bash scripts/get_latest_exiftool.sh && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "media-metadata-cleaner",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "bin/media-metadata-cleaner_exiftool"
    ],
    "resources": {
      "bin/exiftool_files": "exiftool_files"
    },
    "macOS": {
      "files": {
        "MacOS/lib": "bin/lib"
      }
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false,
        "files": {
          "/usr/bin/lib": "bin/lib"
        }
      },
      "deb": {
        "files": {
          "usr/lib/media-metadata-cleaner_exiftool": "bin/lib"
        }
      },
      "rpm": {
        "epoch": 0,
        "files": {
          "/usr/lib/media-metadata-cleaner_exiftool": "bin/lib"
        },
        "release": "1"
      }
    }
  }
}
